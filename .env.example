# Lilypad backend API base (no trailing slash). Used by server-side API routes.
# Local: http://localhost:8081/api
# Test:  https://testbackend.lilypad.co.in:8081/api
BACKEND_API_URL=http://localhost:8081/api

# Iron-session secret (any random string >= 32 chars)
SESSION_PASSWORD=replace-with-a-32-char-or-longer-random-string

# Plain-text login password for the CRM
ADMIN_PASSWORD=changeme
